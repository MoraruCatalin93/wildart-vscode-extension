{
  "name": "WildArt-Agent",
  "displayName": "WildArt Agent",
  "description": "Local AI Agent powered by Ollama",
  "version": "0.0.1",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{
        "id": "wildartAgent",
        "title": "WildArt Agent",
        "icon": "$(robot)"
      }]
    },
    "views": {
      "wildartAgent": [{
        "type": "webview",
        "id": "wildartAgent",
        "name": "WildArt Agent"
      }]
    },
    "commands": [{
      "command": "wildartAgent.clearChat",
      "title": "WildArt Agent: Clear Chat"
    }]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
